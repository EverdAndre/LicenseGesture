@model IEnumerable<LicenseGesture.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
    var ordenacaoAtual = ViewData["OrdenacaoAtual"]?.ToString();
    var direcaoAtual = ViewData["DirecaoAtual"]?.ToString();
    string ProximaDirecao(string coluna) => ordenacaoAtual == coluna && direcaoAtual == "asc" ? "desc" : "asc";
    string SetaOrdenacao(string coluna) => ordenacaoAtual == coluna ? (direcaoAtual == "asc" ? "↑" : "↓") : "↕";
}

<link rel="stylesheet" href="~/css/produto.css" asp-append-version="true" />

<div class="produto-index-header">
    <a class="produto-create-button" asp-action="Create" aria-label="Cadastrar produto">
        <span aria-hidden="true">+</span>
        Cadastrar
    </a>

    <h1>Produtos cadastrados</h1>
<div class="produto-search-form">
   <form asp-action="Index" method="get">
    <input type="text" name="busca" value="@ViewData["BuscaAtual"]" placeholder="Buscar Produto ..." />
    <button type="submit">Buscar</button>
</form>
</div>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>
                        <a asp-action="Index" asp-route-busca="@ViewData["BuscaAtual"]" asp-route-ordenarPor="id" asp-route-direcao="@ProximaDirecao("id")">
                            Id <span class="produto-sort-icon">@SetaOrdenacao("id")</span>
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-busca="@ViewData["BuscaAtual"]" asp-route-ordenarPor="nome" asp-route-direcao="@ProximaDirecao("nome")">
                            Nome <span class="produto-sort-icon">@SetaOrdenacao("nome")</span>
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-busca="@ViewData["BuscaAtual"]" asp-route-ordenarPor="valor" asp-route-direcao="@ProximaDirecao("valor")">
                            Valor de venda <span class="produto-sort-icon">@SetaOrdenacao("valor")</span>
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-busca="@ViewData["BuscaAtual"]" asp-route-ordenarPor="validade" asp-route-direcao="@ProximaDirecao("validade")">
                            Validade <span class="produto-sort-icon">@SetaOrdenacao("validade")</span>
                        </a>
                    </th>
                    <th class="produto-actions-column">Acoes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var produto in Model)
                {
                    <tr>
                        <td>@produto.Id</td>
                        <td>@produto.Nome</td>
                        <td>@(produto.ValorVenda?.ToString("C"))</td>
                        <td>@produto.Validade</td>
                        <td class="produto-actions-cell">
                            <a class="produto-action-button produto-view-button" asp-action="Edit" asp-route-id="@produto.Id" aria-label="Visualizar @produto.Nome" title="Visualizar">
                                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M2.5 12s3.5-6.5 9.5-6.5S21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z" />
                                    <circle cx="12" cy="12" r="2.8" />
                                </svg>
                            </a>

                            <a class="produto-action-button produto-sell-button" asp-controller="Venda" asp-action="Index" asp-route-produtoId="@produto.Id" aria-label="Vender @produto.Nome" title="Vender">
                                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M12 2v20" />
                                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7H14a3.5 3.5 0 0 1 0 7H6" />
                                </svg>
                                <span>Vender</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p>Nenhum produto cadastrado.</p>
}
