@model LicenseGesture.Models.Produto

@{
    ViewData["Title"] = "Produto";
}

<link rel="stylesheet" href="~/css/produto.css" asp-append-version="true" />

<section class="produto-page">
    <div class="produto-hero">
        <div>
            <span class="produto-kicker">Produto</span>
            <h1>Produto</h1>
            <p>@Model.Nome</p>
        </div>
        @if(!string.IsNullOrWhiteSpace(ViewBag.ReturnUrl)){
            <a class="produto-back-link" href="@ViewBag.ReturnUrl">Voltar</a>
        }
        else
        {
            <a class="produto-back-link" asp-action="Index">Voltar</a>
        }
    </div>

    <div class="produto-form">

        <div class="produto-form-grid">
            <div class="produto-section produto-section-main">
                <div class="produto-section-header">
                    <span>01</span>
                    <div>
                        <h2>Identificação</h2>
                        <p>Dados principais da licença cadastrada.</p>
                    </div>
                </div>
                <div class="produto-fields-grid">
                    <div class="produto-field produto-field-wide">
                        <label asp-for="Nome"></label>
                        <div class="produto-readonly-value">
                            @Model.Nome
                        </div>
                    </div>

                    <div class="produto-field produto-field-wide">
                        <label asp-for="Chave"></label>
                        <div class="produto-readonly-value">
                            @Model.Chave
                        </div>
                    </div>

                    <div class="produto-field produto-field-wide">
                        <label asp-for="EmailAdm"></label>
                        <div class="produto-readonly-value">
                            @Model.EmailAdm
                        </div>
                    </div>

                    <div class="produto-field produto-field-wide">
                        <label asp-for="SenhaAdm"></label>
                        <div class="produto-readonly-value">
                            @Model.SenhaAdm
                        </div>
                    </div>

                    <div class="produto-field">
                        <label asp-for="TipoProduto">Tipo de produto</label>
                        <div class="produto-readonly-value">
                            @Model.TipoProduto
                        </div>
                    </div>

                    <div class="produto-field">
                        <label asp-for="Validade"></label>
                        <div class="produto-readonly-value">
                            @Model.Validade
                        </div>
                    </div>
                </div>
            </div>

            <div class="produto-section produto-values-section">
                <div class="produto-section-header">
                    <span>02</span>
                    <div>
                        <h2>Valores e documento</h2>
                        <p>Custos, venda e nota fiscal de entrada.</p>
                    </div>
                </div>

                <div class="produto-fields-grid">
                    <div class="produto-field">
                        <label asp-for="ValorCusto">Valor de custo</label>
                        <div class="produto-readonly-value">
                            @Model.ValorCusto?.ToString("C")
                        </div>
                    </div>

                    <div class="produto-field">
                        <label asp-for="ValorVenda">Valor de venda</label>
                        <div class="produto-readonly-value">
                            @Model.ValorVenda?.ToString("C")
                        </div>
                    </div>

                    <div class="produto-field produto-field-wide">
                        <label asp-for="NfEntrada">NF de entrada</label>
                        <div class="produto-readonly-value">
                            @Model.NfEntrada
                        </div>
                    </div>
                </div>
            </div>

            <div class="produto-section produto-limits-section">
                <div class="produto-section-header">
                    <span>03</span>
                    <div>
                        <h2>Limites de uso</h2>
                        <p>Quantidades permitidas pela licença.</p>
                    </div>
                </div>

                <div class="produto-fields-grid">
                    <div class="produto-field">
                        <label asp-for="Quantidade"></label>
                        <div class="produto-readonly-value">
                            @Model.Quantidade
                        </div>
                    </div>

                    <div class="produto-field">
                        <label asp-for="QuantDispositivos">Dispositivos</label>
                        <div class="produto-readonly-value">
                            @Model.QuantDispositivos
                        </div>
                    </div>

                    <div class="produto-field">
                        <label asp-for="QuantUsuarios">Usuários</label>
                        <div class="produto-readonly-value">
                            @Model.QuantUsuarios
                        </div>
                    </div>
                </div>
            </div>

            <aside class="produto-section produto-status-panel">
                <div class="produto-section-header">
                    <span>04</span>
                    <div>
                        <h2>Status</h2>
                        <p>Ativo.</p>
                    </div>
                </div>

                <div class="produto-status-display">
                    @if (Model.Ativo)
                    {
                        <span class="produto-status produto-status-active">
                            Ativo
                        </span>
                    }
                    else
                    {
                        <span class="produto-status produto-status-inactive">
                            Inativo
                        </span>
                    }
                </div>
            </aside>
        </div>
    </div>
</section>