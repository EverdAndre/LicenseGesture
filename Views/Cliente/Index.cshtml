@model IEnumerable<LicenseGesture.Models.Cliente>

@{
    ViewData["Title"] = "Clientes";
    var ordenacaoAtual = ViewData["OrdenacaoAtual"]?.ToString();
    var direcaoAtual = ViewData["DirecaoAtual"]?.ToString();
    string ProximaDirecao(string coluna) => ordenacaoAtual == coluna && direcaoAtual == "asc" ? "desc" : "asc";
    string SetaOrdenacao(string coluna) => ordenacaoAtual == coluna ? (direcaoAtual == "asc" ? "↑" : "↓") : "↕";
}

<link rel="stylesheet" href="~/css/cliente.css" asp-append-version="true" />

<div class="cliente-index-header">
    <a class="cliente-create-button" asp-action="Create" aria-label="Cadastrar Cliente">
        <span aria-hidden="true">+</span>
        Cadastrar
    </a>

    <h1>Clientes cadastrados</h1>
<div class="cliente-search-form">
   <form asp-action="Index" method="get">
    <input type="text" name="busca" value="@ViewData["BuscaAtual"]" placeholder="Buscar Cliente ..." />
    <button type="submit">Buscar</button>
</form>
</div>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>
                        <a asp-action="Index" asp-route-busca="@ViewData["BuscaAtual"]" asp-route-ordenarPor="id" asp-route-direcao="@ProximaDirecao("id")">
                            Id <span class="cliente-sort-icon">@SetaOrdenacao("id")</span>
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-busca="@ViewData["BuscaAtual"]" asp-route-ordenarPor="nome" asp-route-direcao="@ProximaDirecao("nome")">
                            Nome <span class="cliente-sort-icon">@SetaOrdenacao("nome")</span>
                        </a>
                    <th class="cliente-actions-column">Acoes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cliente in Model)
                {
                    <tr>
                        <td>@cliente.Id</td>
                        <td>@cliente.Nome</td>
                        <td>@(cliente.Telefone?.ToString())</td>
                        <td>@cliente.Email?.ToString()</td>
                        <td class="cliente-actions-cell">
                            <a class="cliente-action-button produto-view-button" asp-action="Edit" asp-route-id="@cliente.Id" aria-label="Visualizar @cliente.Nome" title="Visualizar">
                                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M2.5 12s3.5-6.5 9.5-6.5S21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z" />
                                    <circle cx="12" cy="12" r="2.8" />
                                </svg>
                            </a>

                            <a class="cliente-action-button cliente-sell-button" href="#" data-cliente-id="@cliente.Id" data-cliente-telefone="@cliente.Telefone" aria-label="Chamar @cliente.Nome no WhatsApp" title="WhatsApp">
                                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                    <path d="M20.5 11.8a8.4 8.4 0 0 1-12.4 7.4L3.5 20.5l1.3-4.4A8.4 8.4 0 1 1 20.5 11.8Z" />
                                    <path d="M8.9 7.8c-.2.4-.5.8-.5 1.3 0 1.7 2.4 4.8 5.3 5.8.6.2 1.2.1 1.6-.2l.9-1.1-1.9-.9-.8.8c-1.4-.6-2.5-1.7-3.1-3.1l.8-.8-.9-1.9H8.9Z" />
                                </svg>
                                <span>WhatsApp</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p>Nenhum Cliente cadastrado.</p>
}
