@model IEnumerable<LicenseGesture.Models.Venda>

@{
    ViewData["Title"] = "Home";
    var vendas = Model ?? Enumerable.Empty<LicenseGesture.Models.Venda>();
    var ordenacaoAtual = ViewData["OrdenacaoAtual"]?.ToString();
    var direcaoAtual = ViewData["DirecaoAtual"]?.ToString();
    string ProximaDirecao(string coluna) => ordenacaoAtual == coluna && direcaoAtual == "asc" ? "desc" : "asc";
    string SetaOrdenacao(string coluna) => ordenacaoAtual == coluna ? (direcaoAtual == "asc" ? "↑" : "↓") : "↕";
}

<link rel="stylesheet" href="~/css/venda.css" asp-append-version="true" />

<section class="venda-index-page">
    <div class="venda-index-header">
        <div class="venda-index-title">
            <span class="venda-kicker">Painel de vendas</span>
            <h1>Vendas cadastradas</h1>
        </div>

        <div class="venda-index-actions">
            <form class="venda-search-form" asp-action="Index" method="get">
                <input type="hidden" name="ordenarPor" value="@ordenacaoAtual" />
                <input type="hidden" name="direcao" value="@direcaoAtual" />
                <div class="venda-search-autocomplete">
                    <input id="VendaBusca" type="text" name="busca" value="@ViewData["BuscaAtual"]" placeholder="Buscar venda por cliente ou produto..." autocomplete="off" />
                    <div id="vendaBuscaResultado" class="autocomplete-list"></div>
                </div>
                <button type="submit">Buscar</button>
            </form>

            <a class="venda-create-button" asp-controller="Venda" asp-action="Create" aria-label="Cadastrar venda">
                <span aria-hidden="true">+</span>
                Cadastrar
            </a>
        </div>
    </div>

    @if (vendas.Any())
    {
        <div class="venda-table-card">
            <div class="table-responsive">
                <table class="table venda-table">
                    <thead>
                        <tr>
                            <th>
                                <a asp-action="Index" asp-route-busca="@ViewData["BuscaAtual"]" asp-route-ordenarPor="id" asp-route-direcao="@ProximaDirecao("id")">
                                    Id <span class="venda-sort-icon">@SetaOrdenacao("id")</span>
                                </a>
                            </th>
                            <th>
                                <a asp-action="Index" asp-route-busca="@ViewData["BuscaAtual"]" asp-route-ordenarPor="cliente" asp-route-direcao="@ProximaDirecao("cliente")">
                                    Cliente <span class="venda-sort-icon">@SetaOrdenacao("cliente")</span>
                                </a>
                            </th>
                            <th>
                                <a asp-action="Index" asp-route-busca="@ViewData["BuscaAtual"]" asp-route-ordenarPor="produto" asp-route-direcao="@ProximaDirecao("produto")">
                                    Produto <span class="venda-sort-icon">@SetaOrdenacao("produto")</span>
                                </a>
                            </th>
                            <th>
                                <a asp-action="Index" asp-route-busca="@ViewData["BuscaAtual"]" asp-route-ordenarPor="validade" asp-route-direcao="@ProximaDirecao("validade")">
                                    Expira em <span class="venda-sort-icon">@SetaOrdenacao("validade")</span>
                                </a>
                            </th>
                            <th>Status</th>
                            <th class="venda-actions-column">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var venda in vendas)
                        {
                            var statusClasse = venda.Anulada ? "venda-status-cancelada" : "venda-status-ativa";
                            var statusTexto = venda.Anulada ? "Cancelada" : "Ativa";

                            <tr>
                                <td class="venda-id"># @venda.Id</td>
                                <td>@(venda.Cliente?.Nome ?? $"Cliente #{venda.ClienteId}")</td>
                                <td>@(venda.Produto?.Nome ?? $"Produto #{venda.ProdutoId}")</td>
                                <td>@venda.ExpiraEm.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="venda-status @statusClasse">@statusTexto</span>
                                </td>
                                <td class="venda-actions-cell">
                                    <a class="venda-action-button venda-view-button"
                                        asp-controller="Venda"
                                        asp-action="Details"
                                        asp-route-id="@venda.Id"
                                        aria-label="Visualizar venda @venda.Id"
                                        title="Visualizar">
                                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                            <path d="M2.5 12s3.5-6.5 9.5-6.5S21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z" />
                                            <circle cx="12" cy="12" r="2.8" />
                                        </svg>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="venda-empty-state">
            <span>0</span>
            <h2>Nenhuma venda cadastrada</h2>
            <a class="venda-button venda-button-primary" asp-controller="Venda" asp-action="Create">Cadastrar venda</a>
        </div>
    }
</section>

<script src="~/js/autocomplete.js" asp-append-version="true"></script>
<script src="~/js/venda/buscarVenda.js" asp-append-version="true"></script>
