@model ErrorViewModel
@{
    ViewData["Title"] = "Erro";
}

<section class="content-page">
    <div class="content-card content-card-error">
        <span class="content-kicker">Não foi possível concluir</span>
        <h1>Ocorreu um erro</h1>
        <p>Tente novamente. Se o problema continuar, entre em contato com o responsável pelo sistema.</p>

        @if (Model.ShowRequestId)
        {
            <p class="request-id">
                <strong>Código da solicitação:</strong>
                <code>@Model.RequestId</code>
            </p>
        }

        <a class="content-button" asp-controller="Home" asp-action="Index">Voltar ao início</a>
    </div>
</section>
